ANTHROPIC_API_KEY=            # TODO: sk-ant-...

# --- Voyage AI (embeddings voyage-3.5 + rerank-2.5) — https://dash.voyageai.com ---
VOYAGE_API_KEY=               # TODO: pa-...

# --- Alpha Vantage (official remote MCP) — https://www.alphavantage.co/support/#api-key ---
ALPHAVANTAGE_API_KEY=         # TODO: free key

# --- SEC EDGAR (no key; SEC requires a self-identifying User-Agent) ---
SEC_EDGAR_USER_AGENT="Stav Hecht (stavhecht@gmail.com)"

